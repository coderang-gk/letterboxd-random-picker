<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.LetterboxdWallpaper" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/movie_accent</item>
        <item name="colorOnPrimary">@color/movie_on_accent</item>
        <item name="colorSecondary">@color/movie_accent</item>
        <item name="colorOnSecondary">@color/movie_on_accent</item>
        <item name="colorTertiary">@color/movie_text</item>
        <item name="colorOnSurface">@color/movie_text</item>
        <item name="colorOnSurfaceVariant">@color/movie_muted</item>
        <item name="colorOutline">@color/movie_card_stroke</item>
        <item name="android:windowBackground">@color/movie_bg</item>
        <item name="colorSurface">@color/movie_surface</item>
        <item name="colorSurfaceVariant">@color/movie_surface</item>
        <item name="android:textColor">@color/movie_text</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/movie_topbar</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/movie_bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.LetterboxdWallpaper.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.LetterboxdWallpaper.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.LetterboxdWallpaper.Large</item>
    </style>

    <style name="TextAppearance.LetterboxdWallpaper.ToolbarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/clarity_city_semibold</item>
        <item name="fontFamily">@font/clarity_city_semibold</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textSize">20sp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="ShapeAppearance.LetterboxdWallpaper.Small" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

    <style name="ShapeAppearance.LetterboxdWallpaper.Medium" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="ShapeAppearance.LetterboxdWallpaper.Large" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">30dp</item>
    </style>
</resources>
